VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase edge function secrets for the local RTX planner.
# The URL must be reachable from Supabase, for example a Tailscale Funnel,
# Cloudflare Tunnel, or ngrok URL that points to the OpenAI-compatible router.
LOCAL_LLM_BASE_URL="https://your-router.example/v1"
LOCAL_LLM_API_KEY="your-local-router-token"

# Supabase edge function secrets for local RTX video generation.
# Uses POST {URL}/v1/videos/generations and, for async jobs,
# GET {URL}/v1/videos/generations/{id}.
#
# Preferred (new) names:
LOCAL_VIDEO_ROUTER_URL="https://your-router.example"  # base URL only (no endpoint path)
LOCAL_VIDEO_ROUTER_TYPE="openai_compatible"           # optional; "openai_compatible" (default) or "comfyui"
LOCAL_VIDEO_ROUTER_TOKEN="your-local-router-token"    # optional; sent as Bearer when present
LOCAL_VIDEO_ROUTER_TIMEOUT_MS="300000"                # optional; request timeout, default 300000
# Endpoint paths (joined onto LOCAL_VIDEO_ROUTER_URL):
LOCAL_VIDEO_ROUTER_CREATE_PATH="/videos/generations"  # optional; e.g. /api/generate, or /prompt for ComfyUI
LOCAL_VIDEO_ROUTER_STATUS_PATH="/videos/generations"  # optional; status/poll base path (e.g. /history for ComfyUI)
LOCAL_VIDEO_ROUTER_OUTPUT_PATH="/view"                # optional; ComfyUI output/view path
# ComfyUI only — REQUIRED when LOCAL_VIDEO_ROUTER_TYPE=comfyui.
# Provide your ComfyUI API-format workflow graph as JSON. Placeholders are
# substituted before submission: {{PROMPT}} {{NEGATIVE_PROMPT}} {{IMAGE_URL}}
# {{NUM_FRAMES}} {{FPS}} {{SECONDS}} {{ASPECT_RATIO}} {{SEED}}
LOCAL_VIDEO_COMFY_WORKFLOW_JSON='{"3":{"class_type":"KSampler","inputs":{"seed":{{SEED}}}}}'
#
# Defaults when no CREATE_PATH is set:
#   openai_compatible -> tries /v1/videos/generations then /v1/videos
#   comfyui           -> /prompt
#
# Legacy aliases still honored for backwards compatibility:
# LOCAL_VIDEO_BASE_URL / LOCAL_VIDEO_API_KEY
LOCAL_VIDEO_BASE_URL="https://your-router.example/v1"
LOCAL_VIDEO_API_KEY="your-local-router-token"
