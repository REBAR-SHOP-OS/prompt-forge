VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase edge function secrets for the local RTX planner.
# The URL must be reachable from Supabase, for example a Tailscale Funnel,
# Cloudflare Tunnel, or ngrok URL that points to the OpenAI-compatible router.
LOCAL_LLM_BASE_URL="https://your-router.example/v1"
LOCAL_LLM_API_KEY="your-local-router-token"

# Supabase edge function secrets for local RTX video generation.
# Uses POST {URL}/v1/videos/generations and, for async jobs,
# GET {URL}/v1/videos/generations/{id}.
#
# Preferred (new) names:
LOCAL_VIDEO_ROUTER_URL="https://your-router.example/v1"
LOCAL_VIDEO_ROUTER_TOKEN="your-local-router-token"   # optional; sent as Bearer when present
LOCAL_VIDEO_ROUTER_TIMEOUT_MS="300000"               # optional; request timeout, default 300000
LOCAL_VIDEO_ROUTER_CREATE_PATH="/videos/generations" # optional; use /videos for OpenRouter-compatible routers
#
# Legacy aliases still honored for backwards compatibility:
# LOCAL_VIDEO_BASE_URL / LOCAL_VIDEO_API_KEY
LOCAL_VIDEO_BASE_URL="https://your-router.example/v1"
LOCAL_VIDEO_API_KEY="your-local-router-token"
