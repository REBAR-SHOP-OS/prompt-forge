VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Supabase edge function secrets for the local RTX planner.
# The URL must be reachable from Supabase, for example a Tailscale Funnel,
# Cloudflare Tunnel, or ngrok URL that points to the OpenAI-compatible router.
LOCAL_LLM_BASE_URL="https://your-router.example/v1"
LOCAL_LLM_API_KEY="your-local-router-token"

# Supabase edge function secrets for local RTX video generation.
# Uses POST /v1/videos/generations and, for async jobs, GET /v1/videos/generations/{id}.
# Falls back to LOCAL_AI_ROUTER_BASE_URL / LOCAL_IMAGE_BASE_URL / LOCAL_LLM_BASE_URL if unset.
LOCAL_VIDEO_BASE_URL="https://your-router.example/v1"
LOCAL_VIDEO_API_KEY="your-local-router-token"
